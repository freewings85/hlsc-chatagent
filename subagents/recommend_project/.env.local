# ============================================================
# RecommendProject Subagent 本地开发配置
# ============================================================

USE_NACOS=FALSE

# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=recommend-project
SERVER_HOST=0.0.0.0
SERVER_PORT=8105

# ============================================================
# Temporal（interrupt 机制依赖）
# ============================================================

TEMPORAL_ENABLED=true
TEMPORAL_HOST=localhost:7233
TEMPORAL_DEBUG_MODE=true

# ============================================================
# 可观测性（Logfire / OpenTelemetry）
# ============================================================

# 是否启用 tracing（默认关闭）
LOGFIRE_ENABLED=true
# OTel Collector 地址（设置后 trace 发送到本地服务，不设则发送到 Logfire 云端）
LOGFIRE_ENDPOINT=http://192.168.100.174:4318/v1/traces

# ============================================================
# 文件系统（4 个独立目录）
# ============================================================

# SDK 内部存储（消息、transcript、memory）
INNER_STORAGE_DIR=data/inner

# fs 工具根目录（read/glob/grep 可访问的范围，含 skills 文件）
FS_TOOLS_DIR=data/fstools

# Agent 资源目录（skills、mcp.json）
AGENT_FS_DIR=.chatagent

# 日志目录
LOG_DIR=logs

# 提示词模板目录
PROMPTS_DIR=prompts

MEMORY_SERVICE_TYPE=sqlite

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=200000
COMPACT_OUTPUT_RESERVE=20000
COMPACT_KEEP_RECENT_TOOL_RESULTS=3
COMPACT_MIN_SAVINGS_THRESHOLD=20000
COMPACT_AUTO_BUFFER=13000

# ============================================================
# LLM 连接
# ============================================================

LLM_TYPE=azure
AZURE_DEPLOYMENT_NAME=gpt-5-chat
AZURE_API_VERSION=2024-12-01-preview
AZURE_OPENAI_ENDPOINT=https://51cjml.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=d8d32c5678824e5a95f893177d7a88dc
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2

# ============================================================
# 业务 API
# ============================================================

# DataManager 服务地址
DATAMANAGER_URL= http://192.168.100.108:50400

FUZZY_MATCH_CAR_URL = http://192.168.100.108:50400/service_ai_datamanager/Auto/getCarModelByQueryKey