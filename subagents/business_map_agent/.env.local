# ============================================================
# BusinessMapAgent Subagent 本地开发配置
# ============================================================

USE_NACOS=FALSE

# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=business_map_agent
SERVER_HOST=0.0.0.0
SERVER_PORT=8103

# ============================================================
# 业务地图 YAML 目录（不配置时自动回退到 ../../extensions/business-map/data）
# ============================================================

BUSINESS_MAP_DIR=../../extensions/business-map/data

# 场景配置文件路径（/classify 端点使用）
SCENE_CONFIG_PATH=../../extensions/business-map/scene_config.yaml

# ============================================================
# Temporal（interrupt 机制依赖）
# ============================================================

TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost:7233
TEMPORAL_DEBUG_MODE=true

# ============================================================
# 可观测性（Logfire / OpenTelemetry）
# ============================================================

LOGFIRE_ENABLED=true
LOGFIRE_ENDPOINT=http://127.0.0.1:4318/v1/traces

# ============================================================
# 文件系统（4 个独立目录）
# ============================================================

INNER_STORAGE_DIR=data/inner
FS_TOOLS_DIR=data/fstools
AGENT_FS_DIR=.chatagent
LOG_DIR=logs
PROMPTS_DIR=prompts

MEMORY_SERVICE_TYPE=sqlite

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=200000
COMPACT_OUTPUT_RESERVE=20000
COMPACT_KEEP_RECENT_TOOL_RESULTS=3
COMPACT_MIN_SAVINGS_THRESHOLD=20000
COMPACT_AUTO_BUFFER=13000

# ============================================================
# LLM 连接（小模型，用于导航定位）
# ============================================================

BMA_LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
BMA_LLM_API_KEY=sk-8cf834ae11f94a9d91f7a98960e116cb
BMA_LLM_MODEL=qwen3-30b-a3b
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2
