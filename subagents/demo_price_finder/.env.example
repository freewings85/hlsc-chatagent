# ============================================================
# DemoPriceFinder Subagent 配置模板
# 复制为 .env.local 后填入实际值
# ============================================================

# 是否使用 Nacos 配置中心（生产环境 TRUE，本地开发 FALSE）
USE_NACOS=FALSE

# ============================================================
# Agent 名称 & 服务器
# ============================================================

# Agent 名称（logfire service_name / AgentApp name 共用）
AGENT_NAME=demo-price-finder
SERVER_HOST=0.0.0.0
SERVER_PORT=8101

# ============================================================
# Temporal（interrupt 机制依赖）
# ============================================================

TEMPORAL_ENABLED=true
TEMPORAL_HOST=localhost:7233
# 调试模式：禁用 workflow deadlock 检测（打断点时不会误报）
TEMPORAL_DEBUG_MODE=false

# ============================================================
# 可观测性（Logfire / OpenTelemetry）
# ============================================================

# 是否启用 tracing（默认关闭）
LOGFIRE_ENABLED=false
# OTel Collector 地址
# LOGFIRE_ENDPOINT=http://localhost:4318/v1/traces

# ============================================================
# 文件系统
# ============================================================

# 用户数据目录
USER_FS_DIR=data

# Agent 文件资源目录
AGENT_FS_DIR=.chatagent

# 日志目录
LOG_DIR=logs

# 提示词模板目录
PROMPTS_DIR=prompts

# 会话消息持久化实现（fs 或 sqlite）
MEMORY_SERVICE_TYPE=fs

# ============================================================
# Compact 压缩
# ============================================================

# 是否启用自动压缩
COMPACT_AUTO_ENABLED=true

# 是否启用 Microcompact（Layer 1）
COMPACT_MICROCOMPACT_ENABLED=true

# 模型上下文窗口大小（tokens）
COMPACT_CONTEXT_WINDOW=128000

# 输出预留（tokens）
COMPACT_OUTPUT_RESERVE=8000

# 保留最近 N 个完整 tool result
COMPACT_KEEP_RECENT_TOOL_RESULTS=2

# 最小节省阈值（tokens）
COMPACT_MIN_SAVINGS_THRESHOLD=10000

# Full compact 触发缓冲（tokens）
COMPACT_AUTO_BUFFER=8000

# ============================================================
# LLM 连接
# ============================================================

# LLM 类型：azure 或 openai
LLM_TYPE=azure

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT_NAME=gpt-5-chat

# --- OpenAI / 兼容接口（LLM_TYPE=openai 时使用）---
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- 通用 ---
# 温度参数（0=确定性，1=最大随机）
LLM_TEMPERATURE=0
# API 调用失败重试次数
LLM_MAX_RETRIES=2
