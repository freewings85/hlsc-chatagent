# ============================================================
# DiagnoseAgent Subagent 配置模板
# ============================================================

USE_NACOS=FALSE

AGENT_NAME=diagnose-agent
SERVER_HOST=0.0.0.0
SERVER_PORT=8103

TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost:7233

LOGFIRE_ENABLED=false

# ============================================================
# 文件系统
# ============================================================

INNER_STORAGE_DIR=data/inner
FS_TOOLS_DIR=data/fstools
AGENT_FS_DIR=.chatagent
LOG_DIR=logs
PROMPTS_DIR=prompts
MEMORY_SERVICE_TYPE=fs

# ============================================================
# Compact
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=128000
COMPACT_OUTPUT_RESERVE=8000
COMPACT_KEEP_RECENT_TOOL_RESULTS=2
COMPACT_MIN_SAVINGS_THRESHOLD=10000
COMPACT_AUTO_BUFFER=8000

# ============================================================
# LLM
# ============================================================

LLM_TYPE=azure
AZURE_OPENAI_ENDPOINT=https://51cjml.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=d8d32c5678824e5a95f893177d7a88dc
AZURE_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT_NAME=gpt-5-chat
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2

# ============================================================
# 故障检索 API
# ============================================================

CAR_FAULT_RETRIEVAL_URL=http://localhost:8106/api/faultSearch/retrieval
CAR_FAULT_DATASET_IDS=default
GET_PART_PRIMARY_URL=http://localhost:8106/getPartPrimary
GET_PROJECT_BYCAR_URL=http://localhost:8106/getProjectBycar
