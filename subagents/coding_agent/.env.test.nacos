# Mock API Server 地址
API_BASE_URL=http://127.0.0.1:9000

# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=query-codingagent
SERVER_HOST=0.0.0.0
SERVER_PORT=8102

# ============================================================
# Temporal
# ============================================================

TEMPORAL_ENABLED=false
TEMPORAL_HOST=192.168.100.108:7233
TEMPORAL_DEBUG_MODE=false

# ============================================================
# 可观测性
# ============================================================

LOGFIRE_ENABLED=true
LOGFIRE_ENDPOINT=http://192.168.100.174:4318/v1/traces

# ============================================================
# 文件系统
# ============================================================

INNER_STORAGE_DIR=data/inner
FS_TOOLS_DIR=.chatagent/fstools
CHAT_FS_BACKEND_MODE=global
CODING_AGENT_CODE_BASE_DIR=code_runs
AGENT_FS_DIR=.chatagent
LOG_DIR=logs
PROMPTS_DIR=prompts
MEMORY_SERVICE_TYPE=sqlite

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=128000
COMPACT_OUTPUT_RESERVE=8000
COMPACT_KEEP_RECENT_TOOL_RESULTS=2
COMPACT_MIN_SAVINGS_THRESHOLD=10000
COMPACT_AUTO_BUFFER=8000

# ============================================================
# LLM 连接
# ============================================================

LLM_TYPE=azure
LLM_API_STYLE=responses
AZURE_DEPLOYMENT_NAME=gpt-5.3-codex
AZURE_API_VERSION=2025-04-01-preview
AZURE_OPENAI_ENDPOINT=https://51cjml.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=d8d32c5678824e5a95f893177d7a88dc
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2
