# ============================================================
# QueryCodingAgent Subagent 配置模板
# 复制为 .env.local 后填入实际值
# ============================================================

USE_NACOS=FALSE

# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=query-codingagent
SERVER_HOST=0.0.0.0
SERVER_PORT=8102

# ============================================================
# Temporal（interrupt 机制依赖）
# ============================================================

TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost:7233

# ============================================================
# 可观测性（Logfire / OpenTelemetry）
# ============================================================

LOGFIRE_ENABLED=false

# ============================================================
# 文件系统
# ============================================================

# SDK 内部存储
INNER_STORAGE_DIR=data/inner
# fs 工具根目录（包含 apis/ 与 code_runs/）
FS_TOOLS_DIR=.chatagent/fstools
# chat/stream 和 chat/async 直接使用全局 FS_TOOLS_DIR，而不是 session 隔离目录
CHAT_FS_BACKEND_MODE=global
# 代码工作目录基路径（最终目录 = {base}/{code_task_id}）
CODING_AGENT_CODE_BASE_DIR=code_runs
# bash 工具工作目录（不设则用进程 CWD）
# BASH_CWD=
# Agent 资源目录
AGENT_FS_DIR=.chatagent
LOG_DIR=logs
PROMPTS_DIR=prompts
MEMORY_SERVICE_TYPE=fs

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=128000
COMPACT_OUTPUT_RESERVE=8000
COMPACT_KEEP_RECENT_TOOL_RESULTS=2
COMPACT_MIN_SAVINGS_THRESHOLD=10000
COMPACT_AUTO_BUFFER=8000

# ============================================================
# LLM 连接
# ============================================================

LLM_TYPE=azure
AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT_NAME=gpt-5-chat
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2

# ============================================================
# 命令执行器
# ============================================================

# 执行环境：local（本地 subprocess）或 k8s（kubectl exec 到常驻 Pod）
CODE_EXECUTOR=local

# k8s 模式配置（CODE_EXECUTOR=k8s 时生效）
# K8S_EXECUTOR_NAMESPACE=default
# K8S_EXECUTOR_POD_LABEL=app=code-executor
# K8S_EXECUTOR_CONTAINER=executor

# ============================================================
# 业务 API
# ============================================================

# 业务 API 服务地址（代码脚本中通过 API_BASE_URL 环境变量访问）
API_BASE_URL=http://localhost:9100
