# publish-bidding skill 环境变量
# 这些变量在 invoke_skill 时自动加载，bash 执行脚本时注入

# Mock Tool Server 地址（本地开发）
MOCK_TOOL_SERVER_URL=http://127.0.0.1:8106

# API 地址（脚本中通过 os.getenv 读取，工具通过 skill_env 读取）
GET_PROJECT_PARAM_SCHEMA_URL=http://127.0.0.1:8106/api/projects/paramSchema
INQUIRY_SUBMIT_URL=http://127.0.0.1:8106/api/inquiry/submit
CAR_MODEL_MATCH_URL=http://127.0.0.1:8106/api/car-model/match

# 绕过本地 HTTP 代理（WSL 环境常见问题）
no_proxy=127.0.0.1,localhost
NO_PROXY=127.0.0.1,localhost
