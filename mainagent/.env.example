# ============================================================
# HLSC MainAgent 配置模板
# 复制为 .env.local 后填入实际值
# ============================================================
# 是否使用 Nacos 配置中心（生产环境 TRUE，本地开发 FALSE）
USE_NACOS=FALSE
# ============================================================
# Agent 名称 & 服务器
# ============================================================

# Agent 名称（logfire service_name / AgentApp name 共用）
AGENT_NAME=hlsc-mainagent
SERVER_HOST=0.0.0.0
SERVER_PORT=8100

# ============================================================
# 业务配置
# ============================================================

# Subagent A2A 地址
DEMO_PRICE_FINDER_URL=http://localhost:8101
CODE_AGENT_URL=http://localhost:8102
DIAGNOSE_AGENT_URL=http://localhost:8103
CONFIRM_PROJECT_URL=http://localhost:8104
RECOMMEND_PROJECT_URL=http://localhost:8105

# 会话消息持久化实现
# fs:     每个 session 一个 messages.jsonl，O_APPEND 原子追加
# sqlite: 每个用户一个 messages.db（WAL 模式），支持并发读写
MEMORY_SERVICE_TYPE=sqlite

# ============================================================
# Temporal（interrupt 机制依赖）
# ============================================================

TEMPORAL_ENABLED=true
TEMPORAL_HOST=localhost:7233
# 调试模式：禁用 workflow deadlock 检测（打断点时不会误报）
TEMPORAL_DEBUG_MODE=false

# ============================================================
# 可观测性（Logfire / OpenTelemetry）
# ============================================================

# 是否启用 tracing（默认关闭）
LOGFIRE_ENABLED=false
# OTel Collector 地址（设置后 trace 发送到本地服务，不设则发送到 Logfire 云端）
# LOGFIRE_ENDPOINT=http://localhost:4318/v1/traces

# ============================================================
# Kafka（异步模式 /chat/async）
# ============================================================

# 是否启用 Kafka 异步模式（默认关闭，仅 SSE 模式可用）
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=chat-events

# ============================================================
# 文件系统（4 个独立目录）
# ============================================================

# SDK 内部存储（消息、transcript、memory）
INNER_STORAGE_DIR=data/inner

# fs 工具根目录（read/glob/grep 可访问的范围，含 skills 文件）
FS_TOOLS_DIR=.chatagent/fstools

# bash 工具工作目录（不设则用进程 CWD）
# BASH_CWD=

# Agent 资源目录（skills、mcp.json）
AGENT_FS_DIR=.chatagent

# 日志目录
LOG_DIR=logs

# 提示词模板目录
PROMPTS_DIR=prompts

# ============================================================
# Compact 压缩
# ============================================================

# 是否启用自动压缩（设为 false 完全禁用所有压缩）
COMPACT_AUTO_ENABLED=true

# 是否启用 Microcompact（Layer 1，替换旧 tool result 为占位符）
COMPACT_MICROCOMPACT_ENABLED=true

# 模型上下文窗口大小（tokens）
# GPT-4o: 128000, Claude 3.5 Sonnet: 200000, Claude Opus 4.6: 1000000
COMPACT_CONTEXT_WINDOW=200000

# 输出预留（tokens），有效窗口 = CONTEXT_WINDOW - OUTPUT_RESERVE
COMPACT_OUTPUT_RESERVE=20000

# 保留最近 N 个完整 tool result，更早的替换为占位符
COMPACT_KEEP_RECENT_TOOL_RESULTS=3

# 最小节省阈值（tokens），裁剪节省不到这个数就不执行
COMPACT_MIN_SAVINGS_THRESHOLD=20000

# Full compact 触发缓冲（tokens）
# 触发阈值 = 有效窗口 - AUTO_BUFFER
COMPACT_AUTO_BUFFER=13000

# ============================================================
# LLM 连接
# ============================================================

# LLM 类型：azure 或 openai
LLM_TYPE=azure

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_API_VERSION=2024-12-01-preview
AZURE_DEPLOYMENT_NAME=gpt-5-chat

# --- OpenAI / 兼容接口（LLM_TYPE=openai 时使用）---
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- 通用 ---
# 温度参数（0=确定性，1=最大随机）
LLM_TEMPERATURE=0
# API 调用失败重试次数
LLM_MAX_RETRIES=2

# ============================================================
# 命令执行器（execute_skill_script 用）
# ============================================================

# 执行环境：local（本地 subprocess，默认）或 k8s（kubectl exec 到常驻 Pod）
CODE_EXECUTOR=local

# k8s 模式配置（CODE_EXECUTOR=k8s 时生效）
# K8S_EXECUTOR_NAMESPACE=default
# K8S_EXECUTOR_POD_LABEL=app=code-executor
# K8S_EXECUTOR_CONTAINER=executor

# Skill 脚本 Python 解释器（不设则用当前 agent 进程的 Python）
# SKILL_PYTHON=python3