# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=hlsc-mainagent
SERVER_HOST=0.0.0.0
SERVER_PORT=8100

# ============================================================
# 业务配置（Subagent A2A 地址）
# ============================================================

RECOMMEND_PROJECT_URL=http://192.168.100.108:8105
#DEMO_PRICE_FINDER_URL=http://localhost:8101
CODE_AGENT_URL=http://192.168.100.108:8102
BUSINESS_MAP_AGENT_URL=http://192.168.100.108:8103
CLASSIFY_RECENT_TURNS=3
MEMORY_SERVICE_TYPE=sqlite

#飞哥API
DATA_MANAGER_URL=http://192.168.100.108:50400

COUPON_SEARCH_URL=http://192.168.100.108:8091
SHOP_SEARCH_URL=http://192.168.100.108:8093

#地址服务
ADDRESS_SERVICE_URL=http://192.168.100.108:8092

# classify（BMA RAG）
CLASSIFY_RAG_THRESHOLD=0.6
CLASSIFY_MAX_RESULTS=3

FUZZY_MATCH_CAR_URL = http://192.168.100.108:50400/service_ai_datamanager/Auto/getCarModelByQueryKey
SERVICE_OWNER_URL = http://192.168.100.108:50201/service_owner

AUCTIONEER_URL = http://192.168.100.108:50306

# ============================================================
# Temporal（interrupt 机制依赖）
# ============================================================

TEMPORAL_ENABLED=true
TEMPORAL_HOST=192.168.100.108:7233
# agent_sdk 读的是 TEMPORAL_DEBUG（原 TEMPORAL_DEBUG_MODE 是 typo，不生效）
TEMPORAL_DEBUG=true

# ============================================================
# 可观测性（Logfire / OpenTelemetry）
# ============================================================

LOGFIRE_ENABLED=true
# OTel Collector 地址（设置后 trace 发送到本地服务，不设则发送到 Logfire 云端）
LOGFIRE_ENDPOINT=http://192.168.100.174:4318/v1/traces
# capture http body, default false
LOGFIRE_CAPTURE_HTTP_BODY=true

# ============================================================
# Kafka（异步模式 /chat/async）
# ============================================================

KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=192.168.100.108:9092
KAFKA_TOPIC=chat-events
# ProfileTriggerHook 写的 topic
KAFKA_PROFILE_TOPIC=profile-extract-events

# ============================================================
# 文件系统（4 个独立目录）
# ============================================================

# SDK 内部存储（消息、transcript、memory）
INNER_STORAGE_DIR=data/inner

# fs 工具根目录（read/glob/grep 可访问的范围，含 skills 文件）
FS_TOOLS_DIR=.chatagent/fstools

# Agent 资源目录（skills、mcp.json）
AGENT_FS_DIR=.chatagent

LOG_DIR=logs
PROMPTS_DIR=prompts
MEMORY_SERVICE_TYPE=sqlite

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=200000
COMPACT_OUTPUT_RESERVE=20000
COMPACT_KEEP_RECENT_TOOL_RESULTS=3
COMPACT_MIN_SAVINGS_THRESHOLD=20000
COMPACT_AUTO_BUFFER=13000

# ============================================================
# LLM 连接
# ============================================================

LLM_TYPE=openai
LLM_MODEL=deepseek-v3-2-251201
OPENAI_API_KEY=8da7a381-8568-47d4-8116-decbc12f81ac
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2

# Agent 等 workflow update 返回的墙钟超时（秒）。
# Temporal rpc_timeout 只管单次 poll，execute_update 会一直循环 poll；
# 这个上限防止 tool 阻塞 agent 太久。

# ============================================================
# 命令执行器（execute_skill_script 用）
# ============================================================

CODE_EXECUTOR=local
