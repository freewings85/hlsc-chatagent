dockertag=$(date +"%Y%m%d%H%M")
projectname="com.celiang.hlsc.service.ai.chatagent"
basename="com.celiang.hlsc.service.ai.base"
dockerimage="registry.cn-shanghai.aliyuncs.com/51cjml/test-${projectname}:${dockertag}"

# ењЁ workspace е†…йѓЁе‡†е¤‡ baseпј€е®Њж•ґ cloneпјЊuv.lock pin зљ„ commit еї…йЎ»ењЁ history й‡Њпј‰
if [ -d "${basename}" ]; then
  (cd "${basename}" && git fetch && git reset --hard origin/main)
else
  git clone ssh://git@git.51cjml.com:8022/ai-hlsc/${basename}.git "${basename}"
fi

echo ${dockerimage} > ${projectname}.txt
# scp ${projectname}.txt root@192.168.100.105:/root/
docker build -f mainagent/Dockerfile -t ${dockerimage} .
docker push ${dockerimage}

ssh root@192.168.100.108 "docker rm -f ${projectname}"
ssh root@192.168.100.108 "docker run -itd --restart=always -e ACTIVE=test -e TZ=Asia/Shanghai --name=${projectname} --net=host -v /data/chatagent/mainagent/.chatagent:/app/mainagent/.chatagent -v /data/chatagent/mainagent/logs:/app/mainagent/logs -v /data/chatagent/mainagent/data:/app/mainagent/data ${dockerimage}"
