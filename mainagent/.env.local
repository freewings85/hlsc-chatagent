# ============================================================
# HLSC MainAgent 本地开发配置
# ============================================================

USE_NACOS=FALSE

# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=hlsc-mainagent
SERVER_HOST=0.0.0.0
SERVER_PORT=8100

# ============================================================
# 业务配置
# ============================================================

RECOMMEND_PROJECT_URL=http://192.168.100.108:8105
#DEMO_PRICE_FINDER_URL=http://localhost:8101
CODE_AGENT_URL=http://192.168.100.108:8102
BUSINESS_MAP_AGENT_URL=http://localhost:8103
BUSINESS_MAP_DIR=../extensions/business-map/data
CLASSIFY_RECENT_TURNS=3
MEMORY_SERVICE_TYPE=sqlite

// 飞哥API
DATA_MANAGER_URL=http://localhost:50400
// 大威API
SERVICE_OWNER_URL = http://192.168.100.108:50201/service_owner
// 拍卖师
AUCTIONEER_URL = http://192.168.100.108:50306

COUPON_SEARCH_URL=http://localhost:8091

// 地址服务
ADDRESS_SERVICE_URL=http://localhost:8092

FUZZY_MATCH_CAR_URL = http://192.168.100.108:50400/service_ai_datamanager/Auto/getCarModelByQueryKey

# ============================================================
# Temporal
# ============================================================

TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost:7233

# ============================================================
# Kafka
# ============================================================

KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=chat-events
KAFKA_PROFILE_TOPIC=profile-extract-events

# ============================================================
# 可观测性
# ============================================================
LOGFIRE_ENABLED=true
# OTel Collector 地址（设置后 trace 发送到本地服务，不设则发送到 Logfire 云端）
LOGFIRE_ENDPOINT=http://192.168.100.174:4318/v1/traces
# ============================================================
# 文件系统
# ============================================================

INNER_STORAGE_DIR=data/inner
FS_TOOLS_DIR=.chatagent/fstools
AGENT_FS_DIR=.chatagent
LOG_DIR=logs
PROMPTS_DIR=prompts

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=200000
COMPACT_OUTPUT_RESERVE=20000
COMPACT_KEEP_RECENT_TOOL_RESULTS=3
COMPACT_MIN_SAVINGS_THRESHOLD=20000
COMPACT_AUTO_BUFFER=13000

# ============================================================
# LLM 连接
# ============================================================

LLM_TYPE=openai
LLM_API_STYLE=chat
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=24195f45-9a76-44d9-aa2f-95ab069b14da
LLM_MODEL=ep-20251208175708-wvdnr
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2
SEARCH_COUPON_DEFAULT_RADIUS=100000
