# ============================================================
# HLSC MainAgent 本地开发配置
# ============================================================

USE_NACOS=FALSE

# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=hlsc-mainagent
SERVER_HOST=0.0.0.0
SERVER_PORT=8100

# ============================================================
# 业务配置
# ============================================================

DEMO_PRICE_FINDER_URL=http://localhost:8101
CODE_AGENT_URL=http://localhost:8102
MEMORY_SERVICE_TYPE=sqlite

DATA_MANAGER_URL = http://192.168.100.108:50400

FUZZY_MATCH_CAR_URL = http://192.168.100.108:50400/service_ai_datamanager/Auto/getCarModelByQueryKey

# ============================================================
# Temporal
# ============================================================

TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost:7233

# ============================================================
# 可观测性
# ============================================================

LOGFIRE_ENABLED=true
LOGFIRE_ENDPOINT=http://localhost:4318/v1/traces

# ============================================================
# 文件系统
# ============================================================

INNER_STORAGE_DIR=data/inner
FS_TOOLS_DIR=.chatagent/fstools
AGENT_FS_DIR=.chatagent
LOG_DIR=logs
PROMPTS_DIR=prompts

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=200000
COMPACT_OUTPUT_RESERVE=20000
COMPACT_KEEP_RECENT_TOOL_RESULTS=3
COMPACT_MIN_SAVINGS_THRESHOLD=20000
COMPACT_AUTO_BUFFER=13000

# ============================================================
# LLM 连接
# ============================================================

LLM_TYPE=azure
AZURE_DEPLOYMENT_NAME=gpt-5-chat
AZURE_API_VERSION=2024-12-01-preview
AZURE_OPENAI_ENDPOINT=https://51cjml.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=d8d32c5678824e5a95f893177d7a88dc
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2

# ============================================================
# Scene Classifier（场景识别模型，默认与主模型保持一致）
# ============================================================

CLASSIFY_ENABLED=true

# LLM 类型：azure 或 openai（建议与 LLM_TYPE 一致）
CLASSIFY_LLM_TYPE=azure

# --- Azure OpenAI ---
CLASSIFY_AZURE_OPENAI_ENDPOINT=https://51cjml.cognitiveservices.azure.com/
CLASSIFY_AZURE_OPENAI_API_KEY=d8d32c5678824e5a95f893177d7a88dc
CLASSIFY_AZURE_API_VERSION=2024-12-01-preview
CLASSIFY_AZURE_DEPLOYMENT_NAME=gpt-4.1-mini

# --- OpenAI / 兼容接口（CLASSIFY_LLM_TYPE=openai 时使用）---
# CLASSIFY_OPENAI_API_KEY=your-key
# CLASSIFY_OPENAI_BASE_URL=https://api.openai.com/v1
# CLASSIFY_LLM_MODEL=gpt-4o

# --- 通用 ---
CLASSIFY_LLM_TEMPERATURE=0
CLASSIFY_LLM_MAX_RETRIES=1

# 分类上下文
CLASSIFY_HISTORY_LIMIT=10
CLASSIFY_INCLUDE_USER_MD=true
CLASSIFY_INCLUDE_MEMORY_MD=true
