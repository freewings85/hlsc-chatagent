# ============================================================
# Agent 名称 & 服务器
# ============================================================

AGENT_NAME=hlsc-mainagent-uat
SERVER_HOST=0.0.0.0
SERVER_PORT=8100

# ============================================================
# 业务配置（Subagent A2A 地址）
# ============================================================

RECOMMEND_PROJECT_URL=http://192.168.100.162:8105
#DEMO_PRICE_FINDER_URL=http://localhost:8101
CODE_AGENT_URL=http://192.168.100.162:8102
BUSINESS_MAP_AGENT_URL=http://192.168.100.162:8103
CLASSIFY_RECENT_TURNS=3
MEMORY_SERVICE_TYPE=sqlite

#飞哥API
DATA_MANAGER_URL=http://192.168.100.153:50400

COUPON_SEARCH_URL=http://192.168.100.162:8091
SHOP_SEARCH_URL=http://192.168.100.162:8093

#地址服务
ADDRESS_SERVICE_URL=http://192.168.100.162:8092

FUZZY_MATCH_CAR_URL = http://192.168.100.153:50400/service_ai_datamanager/Auto/getCarModelByQueryKey
SERVICE_OWNER_URL = http://192.168.100.108:50201/service_owner

AUCTIONEER_URL = http://192.168.100.162:50306

# ============================================================
# Temporal（interrupt 机制依赖）
# ============================================================

TEMPORAL_ENABLED=false
TEMPORAL_HOST=192.168.100.108:7233
TEMPORAL_DEBUG_MODE=false

# ============================================================
# 可观测性（Logfire / OpenTelemetry）
# ============================================================

LOGFIRE_ENABLED=true
# OTel Collector 地址（设置后 trace 发送到本地服务，不设则发送到 Logfire 云端）
LOGFIRE_ENDPOINT=http://192.168.100.174:4318/v1/traces
# capture http body, default false
LOGFIRE_CAPTURE_HTTP_BODY=true

# ============================================================
# Kafka（异步模式 /chat/async）
# ============================================================

KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=192.168.100.108:9092
KAFKA_TOPIC=uat-chat-events

# ============================================================
# 文件系统（4 个独立目录）
# ============================================================

# SDK 内部存储（消息、transcript、memory）
INNER_STORAGE_DIR=data/inner

# fs 工具根目录（read/glob/grep 可访问的范围，含 skills 文件）
FS_TOOLS_DIR=.chatagent/fstools

# Agent 资源目录（skills、mcp.json）
AGENT_FS_DIR=.chatagent

LOG_DIR=logs
PROMPTS_DIR=prompts
MEMORY_SERVICE_TYPE=sqlite

# ============================================================
# Compact 压缩
# ============================================================

COMPACT_AUTO_ENABLED=true
COMPACT_MICROCOMPACT_ENABLED=true
COMPACT_CONTEXT_WINDOW=200000
COMPACT_OUTPUT_RESERVE=20000
COMPACT_KEEP_RECENT_TOOL_RESULTS=3
COMPACT_MIN_SAVINGS_THRESHOLD=20000
COMPACT_AUTO_BUFFER=13000

# ============================================================
# LLM 连接
# ============================================================

LLM_TYPE=azure
AZURE_DEPLOYMENT_NAME=gpt-5-chat
AZURE_API_VERSION=2024-12-01-preview
AZURE_OPENAI_ENDPOINT=https://51cjml.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=d8d32c5678824e5a95f893177d7a88dc
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2

# ============================================================
# 命令执行器（execute_skill_script 用）
# ============================================================

CODE_EXECUTOR=local
