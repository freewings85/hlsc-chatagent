USE_NACOS=FALSE

LLM_TYPE=azure
AZURE_DEPLOYMENT_NAME=gpt-5-chat
AZURE_API_VERSION=2024-12-01-preview
AZURE_OPENAI_ENDPOINT=https://51cjml.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=d8d32c5678824e5a95f893177d7a88dc
LLM_TEMPERATURE=0

# ============================================================
# Kafka 配置（异步模式 /chat/async）
# ============================================================
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=chat-events

LOGFIRE_ENABLED=true
#OTel Collector 地址（设置后 trace 发送到本地服务，不设则发送到 Logfire 云端）
LOGFIRE_ENDPOINT=http://localhost:4318/v1/traces

# Temporal 配置
TEMPORAL_ENABLED=true
TEMPORAL_HOST=localhost:7233
TEMPORAL_DEBUG_MODE=true


# ============================================================
# 服务器配置
# ============================================================

SERVER_HOST=0.0.0.0
SERVER_PORT=8100

# ============================================================
# 文件系统配置
# ============================================================

# 用户数据目录（session 对话历史等按用户隔离的文件）
# 路径约定：{USER_FS_DIR}/{user_id}/sessions/{session_id}/messages.jsonl
USER_FS_DIR=data

# Agent 文件资源目录（skills、agent.md 等全局共享文件）
# 集群部署时所有节点共享此目录
AGENT_FS_DIR=.chatagent

# ============================================================
# Compact 压缩配置
# ============================================================

# 是否启用自动压缩（设为 false 完全禁用所有压缩）
COMPACT_AUTO_ENABLED=true

# 是否启用 Microcompact（Layer 1，替换旧 tool result 为占位符）
COMPACT_MICROCOMPACT_ENABLED=true

# 模型上下文窗口大小（tokens）
# GPT-4o: 128000, Claude 3.5 Sonnet: 200000, Claude Opus 4.6: 1000000
COMPACT_CONTEXT_WINDOW=200000

# 输出预留（tokens），计算有效窗口时扣除
# 有效窗口 = CONTEXT_WINDOW - OUTPUT_RESERVE
COMPACT_OUTPUT_RESERVE=20000

# --- Microcompact (Layer 1) ---
# 保留最近 N 个完整 tool result，更早的替换为占位符
# 参考 Claude Code 默认值：3
COMPACT_KEEP_RECENT_TOOL_RESULTS=3

# 最小节省阈值（tokens），裁剪节省不到这个数就不执行
# 避免为几百 tokens 做无意义操作
COMPACT_MIN_SAVINGS_THRESHOLD=20000

# --- Full Compact (Layer 2) ---
# 自动压缩缓冲（tokens）
# Full compact 触发阈值 = 有效窗口 - AUTO_BUFFER
# 参考 Claude Code 默认值：13000
COMPACT_AUTO_BUFFER=13000